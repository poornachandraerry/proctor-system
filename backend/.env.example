PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=proctorai_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=50mb

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Email (SMTP) — optional, emails logged to console if not set
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=ProctorAI
